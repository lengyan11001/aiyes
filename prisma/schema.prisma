generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  USER
  ADMIN
}

enum UserStatus {
  ACTIVE
  DISABLED
}

enum ApiKeyStatus {
  ACTIVE
  REVOKED
}

enum JobStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  CANCELED
}

enum JobKind {
  IMAGE
  VIDEO
}

enum LedgerType {
  CREDIT
  DEBIT
  REFUND
  ADJUSTMENT
}

enum OrderStatus {
  PENDING
  PAID
  CLOSED
  REFUNDED
  FAILED
}

model User {
  id           String       @id @default(cuid())
  username     String       @unique
  email        String?      @unique
  name         String?
  passwordHash String
  role         UserRole     @default(USER)
  status       UserStatus   @default(ACTIVE)
  balanceCents Int          @default(0)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  lastLoginAt  DateTime?
  apiKeys      ApiKey[]
  jobs         GenerationJob[]
  orders       Order[]
  ledgers      UsageLedger[]
}

model ApiKey {
  id            String       @id @default(cuid())
  userId        String
  name          String
  prefix        String
  last4         String
  keyHash       String       @unique
  secretPlain   String?
  status        ApiKeyStatus @default(ACTIVE)
  allowedModels String[]     @default([])
  quotaCents    Int?
  requestLimit  Int?
  usedCents     Int          @default(0)
  usedRequests  Int          @default(0)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  lastUsedAt    DateTime?
  expiresAt     DateTime?
  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobs          GenerationJob[]

  @@index([userId])
  @@index([prefix])
}

model GenerationJob {
  id             String        @id @default(cuid())
  userId         String
  apiKeyId       String?
  upstreamTaskId String?
  kind           JobKind
  model          String
  status         JobStatus     @default(PENDING)
  prompt         String
  params         Json
  result         Json?
  error          String?
  chargedCents   Int           @default(0)
  upstreamPrice  Decimal?      @db.Decimal(12, 4)
  clientIp       String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  completedAt    DateTime?
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  apiKey         ApiKey?       @relation(fields: [apiKeyId], references: [id], onDelete: SetNull)
  ledgers        UsageLedger[]

  @@index([userId, createdAt])
  @@index([upstreamTaskId])
  @@index([status])
}

model UsageLedger {
  id           String     @id @default(cuid())
  userId       String
  apiKeyId     String?
  jobId        String?
  type         LedgerType
  amountCents  Int
  balanceAfter Int
  model        String?
  note         String?
  createdAt    DateTime   @default(now())
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  job          GenerationJob? @relation(fields: [jobId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
}

model Order {
  id              String      @id @default(cuid())
  userId          String
  provider        String      @default("wechat")
  status          OrderStatus @default(PENDING)
  amountCents     Int
  creditsCents    Int
  title           String
  wxPrepayId      String?
  wxTransactionId String?
  raw             Json?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  paidAt          DateTime?
  user            User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([status])
}

model SystemSetting {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt
}
